#!/bin/bash
#
# Pre-commit hook: reject files larger than 50MB to avoid
# triggering GitHub LFS requirements.
#
# To install: git config core.hooksPath .githooks

MAX_SIZE=52428800  # 50MB in bytes
ERRORS=0

# Check staged files (excluding deletions)
while IFS= read -r file; do
    [ -z "$file" ] && continue
    size=$(stat --format="%s" "$file" 2>/dev/null || stat -f "%z" "$file" 2>/dev/null)
    if [ -n "$size" ] && [ "$size" -gt "$MAX_SIZE" ]; then
        echo "ERROR: $file is $(numfmt --to=iec "$size" 2>/dev/null || echo "${size} bytes") (max 50MB)"
        ERRORS=$((ERRORS + 1))
    fi
done < <(git diff --cached --name-only --diff-filter=d)

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "Commit blocked: $ERRORS file(s) exceed the 50MB limit."
    echo "Add large files to .gitignore or use git-lfs."
    exit 1
fi

exit 0
